    {
      "name": "update_risk_settings",
      "risk_tier": "high",
      "method": "PUT",
      "endpoint": "/api/risk",
      "goal": "Обновить whitelisted риск-параметры.",
      "input_schema": {
        "type": "object",
        "required": [
          "updates"
        ],
        "properties": {
          "updates": {
            "type": "object",
            "properties": {
              "base_order_usd": {
                "type": "number",
                "minimum": 5,
                "maximum": 5000
              },
              "max_position_usd": {
                "type": "number",
                "minimum": 10,
                "maximum": 20000
              },
              "stop_loss_pct": {
                "type": "number",
                "minimum": 0.001,
                "maximum": 0.2
              },
              "take_profit_pct": {
                "type": "number",
                "minimum": 0.001,
                "maximum": 0.5
              },
              "margin_pct_balance": {
                "type": "number",
                "minimum": 0.01,
                "maximum": 1
              }
            },
            "additionalProperties": false,
            "minProperties": 1
          }
        },
        "additionalProperties": false
      },
      "preconditions": [
        "Сначала выполнить get_bot_status и get_risk_snapshot",
        "Показать diff до/после и получить подтверждение"
      ]
    },
    {
      "name": "apply_research_experiment",
