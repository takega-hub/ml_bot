              "ai_fallback_min_depth_usd_5": { "type": "number", "minimum": 0 },
              "ai_fallback_imbalance_abs_reduce": { "type": "number", "minimum": 0, "maximum": 5.0 },
              "ai_fallback_orderflow_ratio_low": { "type": "number", "minimum": 0, "maximum": 10.0 },
              "ai_fallback_orderflow_ratio_high": { "type": "number", "minimum": 0, "maximum": 10.0 },
              "decision_engine_allow_score": { "type": "number", "minimum": 0, "maximum": 10.0 },
              "decision_engine_reduce_score": { "type": "number", "minimum": 0, "maximum": 10.0 },
              "decision_engine_w_ml_confidence": { "type": "number", "minimum": 0, "maximum": 10.0 },
              "decision_engine_w_mtf_alignment": { "type": "number", "minimum": 0, "maximum": 10.0 },
              "decision_engine_w_atr_regime": { "type": "number", "minimum": 0, "maximum": 10.0 },
              "decision_engine_w_sr_proximity": { "type": "number", "minimum": 0, "maximum": 10.0 },
              "decision_engine_w_trend_slope": { "type": "number", "minimum": 0, "maximum": 10.0 },
